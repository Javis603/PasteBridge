# Copy this file to .env on the Mac running server.js.

PORT=8765
AUTH_TOKEN=replace-with-a-long-random-shared-secret
SENDER_ID=server-your-mac-name

# Optional TLS. Leave both empty for plain ws:// over a trusted VPN/LAN.
TLS_CERT_PATH=
TLS_KEY_PATH=

MAX_TEXT_BYTES=4MB
MAX_IMAGE_BYTES=25MB
MAX_WS_BUFFER_BYTES=16MB
MESSAGE_CACHE_SIZE=1000
MESSAGE_CACHE_TTL_MS=300000
POLL_INTERVAL_MS=2000
SUPPRESS_MS=5000
HEARTBEAT_INTERVAL_MS=15000
